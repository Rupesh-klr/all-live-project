VITE_API_BASE_URL=http://localhost:5000
# Must be identical to backend ENCRY_MIDDLE_KEY
VITE_ENCRY_MIDDLE_KEY=change_me_32char_aes_passphrase!!

# ── Identity (shown in footers/hero — replaces hard-coded text) ──
# Footer renders as: "© <year> <brand> — <developer> · <tagline>"
VITE_BRAND_NAME=portfolio.hub
VITE_DEVELOPER_NAME=Rupesh
VITE_DEVELOPER_TITLE=Full-Stack Engineer
VITE_PORTFOLIO_TAGLINE=Production-grade engineering
# Optional extra after the tagline (e.g. "6+ years", "Open to work"). Blank = hidden.
# Option 1 — Simple years
VITE_PORTFOLIO_EXPERIENCE="3+ Years of Experience"

# Option 2 — Role focused
VITE_PORTFOLIO_EXPERIENCE="3+ Years in Full Stack Engineering"

# Option 3 — Tech focused
VITE_PORTFOLIO_EXPERIENCE="3+ Years in Java, React & AWS"

# Option 4 — Impact focused
VITE_PORTFOLIO_EXPERIENCE="3+ Years Building Scalable Systems"

# Option 5 — Short & punchy
VITE_PORTFOLIO_EXPERIENCE="3+ Years | Full Stack Engineer"
VITE_PORTFOLIO_EXPERIENCE=
VITE_CONTACT_EMAIL=
VITE_GITHUB_URL=
VITE_LINKEDIN_URL=

